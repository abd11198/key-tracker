    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, FRAME_HEIGHT)

    if not cap.isOpened():
        print("❌ Error: Could not open camera")
        return

    print("\n🚀 Key Movement Notification System Started!")
    print("📋 Features:")
    print("   - IMPROVED: Duplicate detection prevention")
    print("   - IMPROVED: Consistent key tracking with IDs")
    print("   - Notifications ONLY when keys actually move")
    print("   - Real-time movement tracking")
    print("   - Location detection with nearby objects")
    print("   - Movement logging and screenshots")
    print("   - NEW: Location query - Type 'where is [key_name]' in console")
    print("\n⌨️  Press 'q' to quit, 's' to save current frame, 'd' to toggle debug")
    print("🔔 You will be notified when your keys move to a new location!")
    print("💬 Type 'where is [key_name]' in the console to find your keys!")
    print("=" * 60)

    # Start location query thread
    query_thread = check_for_location_query()
    location_thread = threading.Thread(target=query_thread, args=(tracker,), daemon=True)
    location_thread.start()

    frame_count = 0
    fps_start_time = time.time()

    try:
        while True:
            ret, frame = cap.read()
            if not ret:
                print("❌ Error: Could not read frame")
                break

            # Process frame
            processed_frame = tracker.process_frame(frame)

            # Calculate and display FPS
            frame_count += 1
            if frame_count % 30 == 0:
                fps = 30 / (time.time() - fps_start_time)
                fps_start_time = time.time()
                cv2.putText(processed_frame, f"FPS: {fps:.1f}", (FRAME_WIDTH - 100, 30),
                            tracker.font, 0.6, (0, 255, 0), 2)

            # Display frame
            cv2.imshow("🔑 Key Movement Tracker (Duplicate-Free)", processed_frame)

            # Handle key presses
            key = cv2.waitKey(1) & 0xFF
            if key == ord('q'):
                break
            elif key == ord('s'):
                # Manual screenshot
                timestamp = int(time.time())
                manual_shot = f"{SCREENSHOT_DIR}/manual_{timestamp}.jpg"
                cv2.imwrite(manual_shot, processed_frame)
                print(f"📸 Manual screenshot saved: {manual_shot}")
            elif key == ord('d'):
                # Toggle debug mode
                global DEBUG_MODE
                DEBUG_MODE = not DEBUG_MODE
                print(f"🐛 Debug mode: {'ON' if DEBUG_MODE else 'OFF'}")

    except KeyboardInterrupt:
        print("\n⏹️  Interrupted by user")

    except Exception as e:
        print(f"❌ Error occurred: {e}")
        import traceback
        traceback.print_exc()

    finally:
        cap.release()
        cv2.destroyAllWindows()
        print("🏁 Key Movement Tracker stopped")

        # Print final statistics
        print("\n📊 Final Statistics:")
        total_movements = len(tracker.movement_log)
        print(f"   Total movements detected: {total_movements}")
        for key_name, status in tracker.movement_status.items():
            print(f"   {key_name}: Last position tracked")


if __name__ == "__main__":
    main()
