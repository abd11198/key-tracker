def add_new_key(key_name, key_video, key_ref_image):
    global key_data_storage, next_key_id

    if not key_name or not key_video:
        return "❌ Please provide key name and video", key_data_storage

    key_id = next_key_id
    key_data_storage[key_id] = {
        'name': key_name,
        'video': key_video,
        'ref_image': key_ref_image,
        'class_id': key_id
    }
    next_key_id += 1

    return f"✅ Added key '{key_name}' successfully!", key_data_storage

