def save_file(file, save_path):
    with open(save_path, "wb") as f:
        f.write(file)

def extract_frames(video_path, output_dir, target_fps=3, max_frames=2000):
    shutil.rmtree(output_dir, ignore_errors=True)
    os.makedirs(output_dir, exist_ok=True)
    cap = cv2.VideoCapture(video_path)
    fps = cap.get(cv2.CAP_PROP_FPS)
    total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))

    interval = max(1, total // max_frames) if total > max_frames else max(1, int(fps / target_fps))

    i, saved = 0, 0
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        if i % interval == 0:
            if frame.shape[1] != 1280 or frame.shape[0] != 720:
                frame = cv2.resize(frame, (1280, 720))
            cv2.imwrite(f"{output_dir}/frame_{saved:04d}.jpg", frame)
            saved += 1
        i += 1
    cap.release()
    return saved

def detect_key_objects_center_focused(image_path, reference_image_path=None):
    img = cv2.imread(image_path)
    if img is None:
        return []

    img = cv2.resize(img, (1280, 720))
    img_h, img_w = img.shape[:2]
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    center_margin_x = int(img_w * 0.2)
    center_margin_y = int(img_h * 0.2)

    center_x1, center_y1 = center_margin_x, center_margin_y
    center_x2, center_y2 = img_w - center_margin_x, img_h - center_margin_y

    center_region = gray[center_y1:center_y2, center_x1:center_x2]

    reference_descriptors = None
    if reference_image_path and os.path.exists(reference_image_path):
        ref_img = cv2.imread(reference_image_path)
        ref_img = cv2.resize(ref_img, (1280, 720))
        ref_gray = cv2.cvtColor(ref_img, cv2.COLOR_BGR2GRAY)

        ref_center = ref_gray[center_y1:center_y2, center_x1:center_x2]

        sift = cv2.SIFT_create(nfeatures=500)
        _, reference_descriptors = sift.detectAndCompute(ref_center, None)

    blurred = cv2.GaussianBlur(center_region, (5, 5), 0)

    edges1 = cv2.Canny(blurred, 30, 100)
    edges2 = cv2.Canny(blurred, 50, 150)
    edges = cv2.bitwise_or(edges1, edges2)

    kernel_rect = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
    kernel_ellipse = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (5, 5))

    edges = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel_rect)
    edges = cv2.dilate(edges, kernel_ellipse, iterations=1)

    contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    sift = cv2.SIFT_create(nfeatures=300)
    keypoints, descriptors = sift.detectAndCompute(center_region, None)

    key_candidates = []

    for contour in contours:
        area = cv2.contourArea(contour)

        min_area = 800
        max_area = (center_x2 - center_x1) * (center_y2 - center_y1) * 0.4

        if area < min_area or area > max_area:
            continue

        x, y, w, h = cv2.boundingRect(contour)
        aspect_ratio = w / h if h > 0 else 0

        if 0.2 < aspect_ratio < 5.0:
            hull = cv2.convexHull(contour)
            hull_area = cv2.contourArea(hull)
            solidity = area / hull_area if hull_area > 0 else 0

            if 0.25 < solidity < 0.95:
                rect_area = w * h
                extent = area / rect_area if rect_area > 0 else 0

                if extent > 0.15:
                    aspect_score = min(aspect_ratio, 1/aspect_ratio) if aspect_ratio > 0 else 0
                    score = (solidity * 0.4 + extent * 0.3 + aspect_score * 0.3) * (area / max_area)

                    center_region_w = center_x2 - center_x1
                    center_region_h = center_y2 - center_y1
                    obj_center_x = x + w/2
                    obj_center_y = y + h/2

                    dist_from_center = np.sqrt(
                        ((obj_center_x - center_region_w/2) / (center_region_w/2))**2 +
                        ((obj_center_y - center_region_h/2) / (center_region_h/2))**2
                    )
                    center_bonus = max(0, 1 - dist_from_center) * 0.3
                    score += center_bonus

                    if reference_descriptors is not None and descriptors is not None:
                        roi_mask = np.zeros(center_region.shape, dtype=np.uint8)
                        cv2.fillPoly(roi_mask, [contour], 255)
                        roi_keypoints, roi_descriptors = sift.detectAndCompute(center_region, roi_mask)

                        if roi_descriptors is not None and len(roi_descriptors) > 3:
                            bf = cv2.BFMatcher(cv2.NORM_L2, crossCheck=False)
                            matches = bf.knnMatch(reference_descriptors, roi_descriptors, k=2)

                            good_matches = []
                            for match_pair in matches:
                                if len(match_pair) == 2:
                                    m, n = match_pair
                                    if m.distance < 0.7 * n.distance:
                                        good_matches.append(m)

                            if len(good_matches) > 2:
                                similarity_boost = min(len(good_matches) / 15.0, 0.8)
                                score += similarity_boost

                    full_x = center_x1 + x
                    full_y = center_y1 + y

                    x_center = (full_x + w/2) / img_w
                    y_center = (full_y + h/2) / img_h
                    norm_w = w / img_w
                    norm_h = h / img_h

                    key_candidates.append({
                        'bbox': [x_center, y_center, norm_w, norm_h],
                        'score': score,
                        'area': area,
                        'aspect_ratio': aspect_ratio,
                        'solidity': solidity,
                        'center_distance': dist_from_center
                    })

    key_candidates.sort(key=lambda x: x['score'], reverse=True)

    return key_candidates[:1] if key_candidates else []

def create_smart_key_labels_single_detection(image_folder, label_folder, class_id, reference_image_path=None):
    os.makedirs(label_folder, exist_ok=True)
    labeled_count = 0

    print(f"Processing images for class {class_id} with center focus...")
    if reference_image_path:
        print(f"Using reference image: {reference_image_path}")

    for img_name in sorted(os.listdir(image_folder)):
        if not img_name.lower().endswith(".jpg"):
            continue

        img_path = os.path.join(image_folder, img_name)
        label_path = os.path.join(label_folder, img_name.replace(".jpg", ".txt"))

        key_candidates = detect_key_objects_center_focused(img_path, reference_image_path)

        with open(label_path, "w") as f:
            if key_candidates:
                best_key = key_candidates[0]
                bbox = best_key['bbox']
                f.write(f"{class_id} {' '.join(f'{x:.6f}' for x in bbox)}\n")
                labeled_count += 1
                print(f"✅ {img_name}: Key detected (score: {best_key['score']:.3f}, center_dist: {best_key['center_distance']:.3f})")
            else:
                center_bbox = [0.5, 0.5, 0.08, 0.08]
                f.write(f"{class_id} {' '.join(f'{x:.6f}' for x in center_bbox)}\n")
                labeled_count += 1
                print(f"⚠️  {img_name}: No key detected, using center fallback")

    print(f"Labeled {labeled_count} images for class {class_id} (1 detection per frame guaranteed)")
    return labeled_count

def split_dataset(images_dir, labels_dir, base_path, val_ratio=0.2):
    image_list = [f for f in sorted(os.listdir(images_dir)) if f.endswith('.jpg')]
    valid_images = []
    for img_file in image_list:
        lbl_path = os.path.join(labels_dir, img_file.replace(".jpg", ".txt"))
        if os.path.exists(lbl_path) and os.path.getsize(lbl_path) > 0:
            valid_images.append(img_file)

    random.shuffle(valid_images)
    split_idx = int((1 - val_ratio) * len(valid_images))
    train_imgs, val_imgs = valid_images[:split_idx], valid_images[split_idx:]

    for split, files in [("train", train_imgs), ("val", val_imgs)]:
        img_out = os.path.join(base_path, f"images/{split}")
        lbl_out = os.path.join(base_path, f"labels/{split}")
        os.makedirs(img_out, exist_ok=True)
        os.makedirs(lbl_out, exist_ok=True)
        for f in files:
            shutil.copy2(os.path.join(images_dir, f), img_out)
            shutil.copy2(os.path.join(labels_dir, f.replace(".jpg", ".txt")), lbl_out)

    return len(train_imgs), len(val_imgs)

